# ====================================
# Environment Configuration
# ====================================
NODE_ENV=local
PORT=3000
X_API_KEYS=czVtZWFyY2hfa2V5LHRlc3Rfa2V5XzEyMyxkZXZfdGVzdF9rZXk=

# ====================================
# Application Database Connection
# ====================================
# DB_HOST: Use 'mysql' for Docker Compose, 'localhost' for local development
DB_HOST=localhost
DB_PORT=3306
DB_NAME=node_app_dbs
DB_USER=node_user
DB_USERNAME=node_user
DB_PASSWORD=nodepassword

# Prisma connection string (derived from the DB_* values above)
DATABASE_URL="mysql://node_user:nodepassword@localhost:3306/node_app_dbs?connection_limit=10&pool_timeout=30"

# ====================================
# Redis Configuration
# ==============ss===========s===========
# Enable/Disable Redis connection
REDIS_ENABLED=true

# Redis Mode: Use 'false' for standalone, 'true' for cluster
REDIS_CLUSTER_ENABLED=false

# REDIS_HOST: Use 'redis' for Docker Compose, 'localhost' for local development
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_DB=0
REDIS_KEY_PREFIX=nodeapp:
REDIS_CONNECT_TIMEOUT=10000
REDIS_MAX_RETRIES_PER_REQUEST=3

# ====================================
# Logging Configuration
# ====================================
LOG_LEVEL=debug

# Enable/Disable different logger types
LOG_CONSOLE_ENABLED=true
LOG_FILE_ERROR_ENABLED=true
LOG_FILE_INFO_ENABLED=true
LOG_FILE_COMBINED_ENABLED=true
LOG_EXCEPTION_ENABLED=true
LOG_REJECTION_ENABLED=true
LOG_HTTP_ENABLED=true

# Log file configuration
LOG_FILE_MAX_SIZE=20m
LOG_FILE_MAX_DAYS=14d
LOG_FILE_DATE_PATTERN=YYYY-MM-DD

# ====================================
# Docker & MySQL Configuration (for docker-compose.yml)
# ====================================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=node_app_db
MYSQL_USER=node_user
MYSQL_PASSWORD=nodepassword
MYSQL_PORT=3306

BUILD_TARGET=local
VOLUME_SRC=./src
VOLUME_TARGET=/app/src
NGINX_PORT=80

# ====================================
# Database Replication (optional)
# ====================================
DB_REPLICATION=false
DB_WRITE_HOST=mysql-master
DB_WRITE_PORT=3306
DB_WRITE_USER=node_user
DB_WRITE_PASSWORD=nodepassword
DB_READ_HOSTS=mysql-replica-1,mysql-replica-2
DB_READ_PORTS=3306,3306
DB_READ_USERS=node_user,node_user
DB_READ_PASSWORDS=nodepassword,nodepassword

# ====================================
# Database Pool Configuration (optional)
# ====================================
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ====================================
# Database Options (optional)
# ====================================
DB_LOGGING=false
DB_TIMEZONE=+00:00
DB_CHARSET=utf8mb4
DB_COLLATE=utf8mb4_unicode_ci
DB_CONNECT_TIMEOUT=10000

# ====================================
# Database Model Options (optional)
# ====================================
DB_UNDERSCORED=false
DB_FREEZE_TABLE_NAME=false
DB_PARANOID=false

# ====================================
# Database SSL (for production)
# ====================================
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
